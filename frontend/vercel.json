{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://digital-equb-api.onrender.com",
    "VITE_API_BASE_URL": "https://digital-equb-api.onrender.com",
    "VITE_GOOGLE_CLIENT_ID": "375618388845-nus71v4ubvhcrr54jgesi4ne33ol15cv.apps.googleusercontent.com"
  }
}
