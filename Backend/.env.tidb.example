# ============================================================================
# TIDB CLOUD DATABASE CONFIGURATION
# ============================================================================
# Replace these values with your actual TiDB credentials
# Get them from: https://tidbcloud.com/console → Your Cluster → Connect

# TiDB Database Configuration
DB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=4vKxYourPrefix.root
DB_PASSWORD=YourGeneratedPasswordHere
DB_NAME=digital_equb

# ============================================================================
# APPLICATION CONFIGURATION (Keep these the same)
# ============================================================================

# JWT Configuration
JWT_SECRET=digital-equb-jwt-secret-key-2024
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=5000
NODE_ENV=production

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email Configuration (Nodemailer)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
ADMIN_EMAIL=your-admin-email@gmail.com

# ============================================================================
# INSTRUCTIONS
# ============================================================================
# 1. Create TiDB account at https://tidbcloud.com/
# 2. Create a Serverless cluster (FREE)
# 3. Click "Connect" and copy your credentials
# 4. Replace DB_HOST, DB_USER, DB_PASSWORD above
# 5. Rename this file to .env
# 6. Run: node src/database/cli.js migrate
# 7. Update same variables in Render dashboard
# ============================================================================
